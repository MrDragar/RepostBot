# Токен самого бота-рассыльщика (через него идёт управление)
BOT_TOKEN=123456:ABC-DEF...

# ID админов (через запятую)
ADMIN_IDS=[123456789,987654321]

# SOCKS5 прокси (нужно, чтобы aiobots могли слать запросы с территории, где Telegram заблокирован)
PROXY_URL=socks5://user:password@host:port

# Лимит сообщений в секунду (Telegram допускает ~30 msg/s для бота, но лучше меньше)
MESSAGES_PER_SECOND=25

# Папка для временных файлов
TEMP_DIR=./temp
